-- echo initialization
CREATE TABLE function_table(id int, name char(20), score float, u_date date);
CREATE TABLE function_table_2(id int, name char(30), score float, u_date date);
INSERT INTO function_table VALUES (7, 'HCASXNCILL2RYDBZSQ89', 4.08, '2020-12-20');
INSERT INTO function_table VALUES (3, 'KGI', 8.25, '2020-10-02');
INSERT INTO function_table VALUES (8, '4BB80KIKT', 8.58, '2024-06-14');
INSERT INTO function_table VALUES (1, 'HELLO', 3.14, '2020-01-21');
INSERT INTO function_table VALUES (2, 'WORLD', 2.718, '2019-12-31');

-- echo 1. length with constant (CALC)
calc length('hello');
calc length('VUFSBW69MYXBSZXCSRZ68FYDSEJCPD21JJHRFWXPZL2LKCU0TGU3Z6WR0XL0P5HADI4Q0KIPL1GZDJ0N'), length('V9PFKOETEYC9HHITJ7L');

-- echo 2. length with column (SELECT)
-- sort select id, length(name) from function_table;
select length(name) from function_table where id=1;
-- echo 2b. SELECT without FROM (length on string literals)
select length('6N3W0'), length('Z175EJOUZ6AUR8VC09DO78');
-- echo 2c. SELECT without FROM with alias
select length('5W9DJZG5UCRJ1HCI6D9UEMSXVVE1DY0I0TXIAABMS31QQO3ANNHYUU68B8U348960244YET') len1, length('VF1527CX09IA9Q3LZVVYE62B') len2;

-- echo 3. round with constant (CALC)
calc round(3.14159);
calc round(2.718);

-- echo 4. round with column (SELECT)
-- sort select id, round(score) from function_table;
select round(score) from function_table where id=1;
-- echo 4b. ROUND with precision (two args)
select round(8.53, 2) as round_value;
calc round(3.14159, 2);
calc round(2.718, 0);

-- echo 5. date_format with constant (CALC)
calc date_format('2020-01-21', '%Y-%m-%d');
calc date_format('2020-01-21', '%Y');

-- echo 5b. date_format with %D (ordinal) and %M (month name)
calc date_format('2020-01-21', '%D,%M,%Y');
calc date_format('2022-06-28', '%D,%M,%Y');
calc date_format('2019-12-31', '%D,%M,%Y');

-- echo 6. date_format with column (SELECT)
select date_format(u_date, '%Y-%m-%d') from function_table where id=1;
-- echo 6b. date_format with %D,%M,%Y combined with length, round
-- sort select id, length(name), round(score), date_format(u_date, '%D,%M,%Y') as date_type from function_table where id <> 1;

-- echo 7. functions in WHERE
-- sort select * from function_table where length(name) > 5;
select id, name from function_table where length(name) = 5;

-- echo 8. wrong type returns FAILURE
calc length(123);
calc round('3.14');
calc date_format(1, '%Y');
